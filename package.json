{
  "name": "@rackctl/docs",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "shuttering-error-pages --out public --brand rackctl --ground slate --palette slate --home https://docs.rackctl.sh && rm -f public/404.html",
    "build": "astro build",
    "postbuild": "shuttering-error-pages check dist/500.html --status 500",
    "preview": "astro preview",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.41.3",
    "@shuttering/starlight": "^0.2.0",
    "astro": "^7.0.7",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@shuttering/error-pages": "^0.3.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@shuttering/starlight": "https://registry.npmjs.org/@shuttering/starlight/-/starlight-0.2.0.tgz"
    }
  }
}
